# ----------------------------------------------------------------------------
# docrag 環境變數範本。複製為 .env 並填入實際值（.env 已被 gitignore）。
# 這些變數由 application.yml 以 ${VAR:default} 形式參照。
# ----------------------------------------------------------------------------

# ===== 資料庫 (PostgreSQL 18 + pgvector) =====
DB_URL=jdbc:postgresql://localhost:5432/docrag
DB_USERNAME=docrag
DB_PASSWORD=docrag

# ===== Embedding 維度 =====
# OpenAI text-embedding-3-small = 1536；Ollama nomic-embed-text = 768。
# 必須與所選 embedding 模型一致，且資料庫一旦建表即固定（換維度需重建 chunks）。
EMBEDDING_DIMENSION=1536

# ===== Provider 選擇 =====
# 對應 Spring AI 的 model bean 名稱：
#   embedding: openAiEmbeddingModel | ollamaEmbeddingModel
#   llm:       openAiChatModel      | ollamaChatModel | anthropicChatModel
APP_EMBEDDING_BEAN=openAiEmbeddingModel
APP_LLM_BEAN=openAiChatModel

# ===== OpenAI =====
OPENAI_API_KEY=sk-replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ===== Ollama (本機) =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=gemma2:2b

# ===== Anthropic / Claude（生成；可選） =====
# 啟用方式：設 APP_LLM_BEAN=anthropicChatModel，並填入下方金鑰。
# 模型 ID 必須是精確字串、不可加日期後綴：
#   claude-opus-4-8（最強，預設）｜ claude-sonnet-4-6（速度/成本均衡）｜ claude-haiku-4-5（最便宜）
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=4096
# 選用：透過自架閘道/代理時覆寫（預設 https://api.anthropic.com）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ===== Redis (僅 'redis' profile 需要) =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== 限流 (ADR-009) =====
# 選用存取碼：設定後，/api/query/** 需帶 X-Access-Code 標頭。留空則停用。
APP_ACCESS_CODE=
